{
  "name": "@paxeer-network/v5-asamm",
  "version": "0.1.0",
  "description": "v5 Adaptive Sigmoid Automated Market Maker — a novel AMM with progressive fees, on-chain order book, and Diamond Standard architecture",
  "license": "GPL-3.0-only",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "compile": "hardhat compile",
    "compile:forge": "forge build",
    "test": "hardhat test",
    "test:forge": "forge test -vvv",
    "test:coverage": "hardhat coverage",
    "test:gas": "REPORT_GAS=true hardhat test",
    "test:fuzz": "forge test --fuzz-runs 10000 -vvv",
    "lint": "npm run lint:sol && npm run lint:ts",
    "lint:sol": "solhint 'src/**/*.sol'",
    "lint:ts": "eslint '**/*.ts'",
    "format": "prettier --write 'src/**/*.sol' 'test/**/*.ts' 'scripts/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.sol' 'test/**/*.ts' 'scripts/**/*.ts'",
    "slither": "slither . --config-file slither.config.json",
    "deploy:local": "hardhat run scripts/deploy.ts --network hardhat",
    "deploy:paxeer": "hardhat run scripts/deploy.ts --network paxeer-network",
    "verify": "hardhat verify --network paxeer-network",
    "clean": "hardhat clean && forge clean && rm -rf coverage typechain-types",
    "size": "hardhat size-contracts",
    "snapshot": "forge snapshot",
    "typechain": "hardhat typechain"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-ignition": "0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.12",
    "@nomicfoundation/ignition-core": "0.15.15",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "chai": "^4.5.0",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.1",
    "ethers": "^6.13.4",
    "hardhat": "^2.22.17",
    "hardhat-contract-sizer": "^2.10.0",
    "hardhat-gas-reporter": "^2.2.2",
    "prettier": "^3.4.2",
    "prettier-plugin-solidity": "^1.4.1",
    "solhint": "^5.0.3",
    "solidity-coverage": "^0.8.14",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.7.2"
  }
}
