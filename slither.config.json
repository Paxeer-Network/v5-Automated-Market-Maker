{
  "detectors_to_run": "all",
  "exclude_informational": false,
  "exclude_low": false,
  "exclude_medium": false,
  "exclude_high": false,
  "solc_remaps": [
    "@core/=src/core/",
    "@periphery/=src/periphery/",
    "@tokens/=src/tokens/",
    "@utils/=src/utils/"
  ],
  "solc_args": "--optimize --optimize-runs 200",
  "filter_paths": "test/|scripts/|node_modules/"
}