# Railway provides DATABASE_URL and REDIS_URL automatically
# For local dev, set these manually:
DATABASE_URL=postgresql://postgres:password@localhost:5432/asamm_indexer
REDIS_URL=redis://localhost:6379

# Chain config
RPC_URL=https://public-rpc.paxeer.app/rpc
EVENT_EMITTER_ADDRESS=0x3FCa66c12B99e395619EE4d0aeabC2339F97E1FF
CHAIN_ID=125

# Indexer config
START_BLOCK=0
POLL_INTERVAL_MS=3000
BATCH_SIZE=1000

# Server config
PORT=4000
